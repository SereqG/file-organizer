APP_NAME="File Organizer"
DEBUG=false
HOST=0.0.0.0
PORT=8000
# OpenRouter API keys are supplied per-user from the browser (Run Settings) — never via env.
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Sandboxed demo (leave unset to use the defaults under apps/backend/var) ---
# SANDBOX_ROOT=
# SQLITE_PATH=
# SESSION_TTL_SECONDS=3600
# QUOTA_MAX_BYTES=52428800
# QUOTA_MAX_FILES=1000
# QUOTA_MAX_FOLDERS=1000
# MAX_WORKFLOW_NODES=100
# MAX_RUNTIME_SECONDS=30
# CLEANUP_INTERVAL_SECONDS=300
