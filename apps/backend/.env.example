APP_NAME="File Organizer"
DEBUG=false
HOST=0.0.0.0
PORT=8000
# OpenRouter API keys are supplied per-user from the browser (Run Settings) — never via env.
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Sandboxed demo (leave unset to use the defaults under apps/backend/var) ---
# SANDBOX_ROOT=
# SQLITE_PATH=
# SESSION_TTL_SECONDS=3600
# QUOTA_MAX_BYTES=52428800
# QUOTA_MAX_FILES=1000
# QUOTA_MAX_FOLDERS=1000
# MAX_WORKFLOW_NODES=100
# MAX_RUNTIME_SECONDS=30
# CLEANUP_INTERVAL_SECONDS=300
# MAX_SESSIONS=500
# SESSION_CREATE_RATE_LIMIT=10/minute
# MAX_DEFINITION_BYTES=262144
# MAX_DEFINITIONS_PER_SESSION=50

# Shared secret the frontend proxy must present on every backend call (defense-in-depth). Leave
# unset locally to disable the check; required (and matched on both services) under docker-compose.
# INTERNAL_API_SECRET=

